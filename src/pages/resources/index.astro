---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Section } from "@/components/ui/section";
import { ResourceList } from "@/components/features/ResourceList";
import PageHeader from "@/components/features/PageHeader.astro";
import { resources } from "@/data/resources";
---

<BaseLayout
  title="Testing & engineering resources for R developers"
  description="The books, talks, and references on testing, TDD, BDD, and software engineering that shaped how I build R and Shiny apps — plus a few design picks."
  image="/ogimg-resources.png"
>
  <Section variant="dark">
    <div class="container mx-auto py-16 lg:py-24 px-4">
      <PageHeader
        label="Resources"
        subtitle="The resources that shaped how I work"
      />
      <ResourceList client:load items={resources} />
    </div>
  </Section>
</BaseLayout>
