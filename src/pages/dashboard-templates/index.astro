---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NotebookPage from "@/components/ui/notebook/NotebookPage.astro";
import { Section } from "@/components/ui/section";
import PageHeader from "@/components/features/PageHeader.astro";
import DashboardTemplateCards from "./DashboardTemplateCards.tsx";
---

<BaseLayout
  title="Dashboard Templates"
  meta="Beautiful Shiny dashboard templates ready to use for your applications. Professional designs and layouts."
>
  <NotebookPage>
    <Section variant="dark">
      <div class="container mx-auto px-4 pt-16 lg:pt-24">
        <PageHeader
          label="Dashboard Templates"
          subtitle="Ready to use for your apps."
        />
        <DashboardTemplateCards client:load />
      </div>
    </Section>
  </NotebookPage>
</BaseLayout>
