---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Section } from "@/components/ui/section";
import IDEInterface from "../../components/file-viewer/IDEInterface.jsx";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import {
  buildRepositoryFileTree,
  createGitHubAuthHeaders,
  fetchDirectoryReadme,
  fetchTopLevelDirectories,
} from "@/lib/rTestsGallery";

// Create markdown processor with the same config as astro.config.mjs
const markdownProcessor = await createMarkdownProcessor({
  syntaxHighlight: "shiki",
  shikiConfig: {
    theme: "github-dark",
    langs: [],
    wrap: true,
    transformers: [],
  },
});

// Helper function to render full markdown content
const renderMarkdown = async (content: string) => {
  try {
    const result = await markdownProcessor.render(content);
    return result.code;
  } catch (error) {
    console.error("Error rendering markdown:", error);
    return content;
  }
};

export async function getStaticPaths() {
  const headers = createGitHubAuthHeaders(import.meta.env.PRIVATE_GITHUB_TOKEN);

  try {
    const relevantDirs = await fetchTopLevelDirectories(headers);

    // If API failed or returned no dirs, return empty paths
    if (relevantDirs.length === 0) {
      console.error("No directories found or API failed");
      return [];
    }

    const paths: any[] = [];

    for (const dirName of relevantDirs) {
      let fileTree: any[] = [];
      let hasError = false;

      fileTree = await buildRepositoryFileTree(dirName, headers, 3);

      // If API failed or returned empty tree, mark as error
      if (fileTree.length === 0) {
        hasError = true;
      }

      const readmeContent = await fetchDirectoryReadme(dirName, headers);

      paths.push({
        params: { slug: dirName },
        props: {
          dirName,
          fileTree: fileTree,
          readmeContent: readmeContent,
          hasError: hasError,
        },
      });
    }

    return paths;
  } catch (error) {
    console.error("Error in getStaticPaths:", error);
    // Return empty paths instead of fallback
    return [];
  }
}

const { dirName, fileTree, readmeContent, hasError } = Astro.props as {
  dirName: string;
  fileTree: any[];
  readmeContent: string;
  hasError: boolean;
};

// Process README content for rendering
let renderedReadmeContent = "";
if (readmeContent) {
  renderedReadmeContent = await renderMarkdown(readmeContent);
}
---

<BaseLayout title={`R Tests Gallery`} image="/ogimg-home.png">
  <main>
    {
      renderedReadmeContent && (
        <Section variant="light" className="pt-[60px] pb-10" id="hero">
          <article
            class="mx-auto
              prose
              dark:prose-invert
              font-serif
              prose-h1:font-sans prose-h1:capitalize prose-h1:mb-2 prose-h1:font-semibold
              prose-h2:font-sans prose-h2:font-semibold prose-h2:my-6
              prose-h3:font-sans prose-h3:font-medium prose-h3:my-4
              prose-h4:font-sans prose-h4:font-medium prose-h4:my-2
              prose-p:my-2
              prose-code:font-mono
              prose-pre:font-code
              prose-pre:rounded-none
              prose-blockquote:bg-ocean-green-100/50
              prose-blockquote:border-none
              prose-blockquote:rounded-lg
              prose-blockquote:py-4
              prose-blockquote:not-italic
              prose-blockquote:transition-all
              hover:prose-blockquote:bg-ocean-green-200/50
              prose-img:w-full
              px-2"
          >
            <Fragment set:html={renderedReadmeContent} />
          </article>
        </Section>
      )
    }
    <Section id="code" variant="light">
      <div class="py-8 container mx-auto">
        <IDEInterface
          fileTree={fileTree}
          dirName={dirName}
          hasError={hasError}
          client:load
        />
      </div>
    </Section>
  </main>
</BaseLayout>
