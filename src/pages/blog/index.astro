---
import { BlogPage } from "@/components/features/BlogPage";
import type { BlogListItem } from "@/components/features/BlogPage";
import { Section } from "@/components/ui/section";
import { getCollection } from "astro:content";
import { getReadingTime } from "@/utils/getReadingTime";
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotebookPage from "@/components/ui/notebook/NotebookPage.astro";

const FEATURED_SLUGS = [
  "bdd-shiny-feature",
  "bdd-shiny-when",
  "bdd-shiny-given",
];

// Length of the server-trimmed preview shipped for the featured hero card.
const EXCERPT_CHARS = 1200;

// Map to a lightweight shape. We deliberately drop each post's full markdown
// `body` here: reading time is computed on the server, and only the featured
// posts carry a short excerpt. This keeps the hydrated island small.
const posts: BlogListItem[] = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((post) => post.data.draft !== true)
  .map((post) => ({
    slug: post.slug,
    // Only the fields the cards render — keeps the hydration blob lean.
    data: {
      title: post.data.title,
      description: post.data.description,
      pubDate: post.data.pubDate,
      tags: post.data.tags,
    },
    readingTime: getReadingTime(post.body),
    excerpt: FEATURED_SLUGS.includes(post.slug)
      ? post.body.slice(0, EXCERPT_CHARS)
      : undefined,
  }));
---

<BaseLayout
  title="Blog — Testing R & Shiny Apps | Jakub Sobolewski"
  description="In-depth, practical articles on testing in R and Shiny: TDD, BDD, mutation testing, test architecture, and the tooling that makes your test suite trustworthy."
>
  <NotebookPage>
    <Section id="blog" variant="dark">
      <h1 class="sr-only">Blog — testing in R and Shiny</h1>
      <BlogPage client:load posts={posts} featuredSlugs={FEATURED_SLUGS} />
    </Section>
  </NotebookPage>
</BaseLayout>
