---
import { BlogPage } from "@/components/features/BlogPage";
import { Section } from "@/components/ui/section";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const FEATURED_SLUGS = [
  "bdd-shiny-feature",
  "bdd-shiny-when",
  "bdd-shiny-given",
];

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((post) => post.data.draft !== true);
---

<BaseLayout>
  <Section id="blog" variant="dark">
    <BlogPage client:load posts={posts} featuredSlugs={FEATURED_SLUGS} />
  </Section>
</BaseLayout>

<style is:global>
  /* Mobile: single-column auto-flow, no separator height */
  @media (max-width: 767px) {
    .blog-grid {
      --blog-row-min: 0px;
      --sep-row-h: 0px;
    }
    .blog-grid > * {
      grid-column: 1 !important;
      grid-row: auto !important;
    }
  }

  /* Below lg: hide gap columns (tablet gets full content width, mobile already reset above) */
  @media (max-width: 1023px) {
    .blog-gap {
      display: none !important;
    }
  }

  /* md (10-col): content fills cols 1-10 */
  @media (min-width: 768px) {
    .blog-sidebar { grid-column: 1 / 3; }
    .blog-post-left { grid-column: 3 / 7; }
    .blog-post-right { grid-column: 7 / 11; }
  }

  /* lg (12-col): content in cols 2-11 with gap cols on sides */
  @media (min-width: 1024px) {
    .blog-sidebar { grid-column: 2 / 4; }
    .blog-post-left { grid-column: 4 / 8; }
    .blog-post-right { grid-column: 8 / 12; }
  }

  @media (min-width: 768px) {
    .blog-empty-state { grid-column: 3 / 11; }
    .blog-gap-left { grid-column: 1 / 2; }
    .blog-gap-right { grid-column: 10 / 11; }
  }
  @media (min-width: 1024px) {
    .blog-empty-state { grid-column: 4 / 12; }
    .blog-gap-left { grid-column: 1 / 2; }
    .blog-gap-right { grid-column: 12 / 13; }
  }
</style>
