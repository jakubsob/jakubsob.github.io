---
import BaseLayout from "./BaseLayout.astro";
import BlogPostJSONLD from "../components/features/BlogPostJSONLD.astro";
import FormattedDate from "../components/features/FormattedDate";
import { Section } from "@/components/ui/section";
import { Button } from "@/components/ui/button";
import { TagList } from "@/components/features/TagList";
import { Asterisk, ExternalLink } from "lucide-react";
import GetRoadmapButton from "@/components/features/GetRoadmapButton.astro";
import { getReadingTime } from "../utils/getReadingTime";
import TableOfContents from "../components/features/TableOfContents";
import PostList from "@/components/features/PostList";
import { getCollection } from "astro:content";
import { proseClasses } from "@/lib/prose";
import { ArrowLeft, ArrowRight } from "lucide-react";

// `trackContext` is only supplied by the /learn/[track]/[lesson] reading route.
// On the plain /blog route it is undefined, so no lesson navigation renders —
// a reader arriving cold via search/blog isn't pushed into a sequence.
// `canonicalURL` lets the lesson route point back at the canonical /blog page.
const { post, trackContext, canonicalURL } = Astro.props;
const readingTime = getReadingTime(post.body);
const { title, description, pubDate, updatedDate, tags } = post.data;
const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((post) => post.data.tags.some((tag) => tags.includes(tag)))
  .filter((post) => post.data.title !== title)
  .filter((post) => post.data.draft !== true)
  .filter((_, index) => index < 3);
---

<style is:global>
  /* Remove default quote marks from blockquotes */
  .prose blockquote p::before,
  .prose blockquote p::after {
    content: none !important;
  }
</style>

<BaseLayout
  {...post.data}
  ogType="article"
  image={`/blog/${post.slug}/og-image.png`}
  canonicalURL={canonicalURL}
>
  <BlogPostJSONLD slot="head" {...post.data} slug={post.slug} />
  <Section variant="dark" className="pt-14">
    <div
      class="w-full xl:max-w-screen-xl 2xl:max-w-[1400px] xl:mx-auto border-x px-4 grid grid-cols-1 lg:grid-cols-[1fr_65ch_1fr] gap-8"
    >
      <div class="hidden lg:block">
        <div
          id="pkg-banner"
          class="sticky top-14 py-2 flex flex-col gap-3 p-4 text-xs"
        >
          <button
            id="pkg-banner-toggle"
            aria-label="Toggle packages"
            aria-expanded="true"
            class="flex items-center justify-between w-full text-left cursor-pointer hover:text-foreground transition-colors"
          >
            <span
              class="uppercase tracking-wide text-muted-foreground font-medium"
              >Try out my testing packages!</span
            >
            <span
              id="pkg-banner-caret"
              class="inline-block text-muted-foreground leading-none transition-transform duration-300 rotate-0"
              >⌄</span
            >
          </button>
          <div
            id="pkg-banner-content"
            class="grid [grid-template-rows:1fr] overflow-hidden transition-all duration-300 opacity-100"
          >
            <a
              href="https://github.com/jakubsob/cucumber"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 no-underline group"
            >
              <img
                src="https://raw.githubusercontent.com/jakubsob/cucumber/main/man/figures/logo.png"
                alt="cucumber logo"
                width="28"
                height="28"
                class="object-contain flex-shrink-0 grayscale opacity-50"
              />
              <div>
                <div
                  class="font-medium group-hover:text-primary transition-colors"
                >
                  cucumber
                </div>
                <div class="text-muted-foreground">BDD testing for R</div>
              </div>
            </a>
            <a
              href="https://github.com/jakubsob/muttest"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 no-underline group grayscale"
            >
              <img
                src="https://raw.githubusercontent.com/jakubsob/muttest/main/man/figures/logo.png"
                alt="muttest logo"
                width="28"
                height="28"
                class="object-contain flex-shrink-0 grayscale opacity-30"
              />
              <div>
                <div
                  class="font-medium group-hover:text-primary transition-colors"
                >
                  muttest
                </div>
                <div class="text-muted-foreground">Mutation testing for R</div>
              </div>
            </a>
          </div>
        </div>
      </div>
      <div class="lg:col-start-2">
        <article class={`mx-auto ${proseClasses} px-2`}>
          <header class="border-b pb-6">
            {
              trackContext && (
                <a
                  href={`/learn/${trackContext.track.id}/`}
                  class="not-prose group inline-flex items-center gap-2 text-xs uppercase tracking-wide text-muted-foreground hover:text-foreground transition-colors no-underline mb-2"
                >
                  <span>
                    Part of{" "}
                    <strong class="font-medium">
                      {trackContext.track.title}
                    </strong>
                  </span>
                  <span class="text-muted-foreground/50">·</span>
                  <span class="tabular-nums">
                    Lesson {trackContext.position} of {trackContext.total}
                  </span>
                </a>
              )
            }
            <h1 class="text-balance">{title}</h1>
            {
              description && (
                <p class="text-xl font-normal text-muted-foreground m-0">
                  {description}
                </p>
              )
            }
            <div
              class="flex flex-row flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted-foreground/60 uppercase"
            >
              <div>
                {pubDate && <FormattedDate date={pubDate} />}
                {
                  updatedDate && (
                    <div>
                      Last updated on <FormattedDate date={updatedDate} />
                    </div>
                  )
                }
              </div>
              <TagList tags={tags} linked={true} client:load />
              <span class="ml-auto tabular-nums">
                {readingTime}
              </span>
            </div>
          </header>
          <slot />
          {
            trackContext && (trackContext.prev || trackContext.next) && (
              <nav
                aria-label="Track navigation"
                class="not-prose pt-10 mt-10 bg-secondary"
              >
                <a
                  href={`/learn/${trackContext.track.id}/`}
                  class="block text-xs uppercase tracking-wide text-muted-foreground hover:text-foreground transition-colors no-underline mb-4"
                >
                  {trackContext.track.title} · Lesson {trackContext.position} of{" "}
                  {trackContext.total}
                </a>
                <div class="grid grid-cols-1 sm:grid-cols-2">
                  {trackContext.prev ? (
                    <a
                      href={`/learn/${trackContext.track.id}/${trackContext.prev.slug}/`}
                      class="group flex flex-col gap-1 border p-4 no-underline hover:bg-light transition-colors"
                    >
                      <span class="inline-flex items-center gap-1 text-xs uppercase tracking-wide text-muted-foreground">
                        <ArrowLeft className="size-[1em]" /> Previous
                      </span>
                      <span class="font-medium text-balance group-hover:text-primary transition-colors">
                        {trackContext.prev.post.data.title}
                      </span>
                    </a>
                  ) : (
                    <div />
                  )}
                  {trackContext.next && (
                    <a
                      href={`/learn/${trackContext.track.id}/${trackContext.next.slug}/`}
                      class="group flex flex-col gap-1 border p-4 no-underline hover:bg-light transition-colors sm:text-right"
                    >
                      <span class="inline-flex items-center gap-1 text-xs uppercase tracking-wide text-muted-foreground sm:justify-end">
                        Next <ArrowRight className="size-[1em]" />
                      </span>
                      <span class="font-medium text-balance group-hover:text-primary transition-colors">
                        {trackContext.next.post.data.title}
                      </span>
                    </a>
                  )}
                </div>
              </nav>
            )
          }
          <div
            class="flex flex-col md:flex-row gap-6 md:gap-12 justify-between py-24"
          >
            <div class="w-full">
              <GetRoadmapButton />
            </div>
            <div class="flex items-center justify-center text-muted">or</div>
            <a
              href="https://github.com/jakubsob/r-tests-gallery/issues/new/choose"
              target="_blank"
              class="flex items-center gap-2 no-underline w-full"
              rel="noopener noreferrer"
            >
              <Button
                variant="pill"
                shape="pill"
                className="flex-1 font-light h-auto"
              >
                <ExternalLink className="size-[1em]" />
                <div>Submit a content request</div>
              </Button>
            </a>
          </div>
        </article>
      </div>
      <div class="relative">
        <TableOfContents client:load />
      </div>
    </div>
  </Section>
  <Section variant="light">
    <div class="container mx-auto grid grid-cols-1 gap-2 max-w-[65ch]">
      <div class="py-24">
        <h2 class="text-2xl lg:text-3xl mb-6 flex items-center uppercase">
          <Asterisk className="size-[1em] block" />
          <span>You might also like</span>
        </h2>
        <PostList posts={posts} showControls={false} />
      </div>
    </div>
  </Section>
  <script is:inline>
    const content = document.getElementById("pkg-banner-content");
    const toggleBtn = document.getElementById("pkg-banner-toggle");
    const caret = document.getElementById("pkg-banner-caret");
    if (content) {
      const inner = document.createElement("div");
      inner.className = "min-h-0 flex flex-col gap-3";
      while (content.firstChild) inner.appendChild(content.firstChild);
      content.appendChild(inner);
    }
    function setCollapsed(collapsed, animate) {
      if (!content || !toggleBtn) return;
      if (!animate) content.classList.add("!transition-none");
      content.classList.toggle("[grid-template-rows:0fr]", collapsed);
      content.classList.toggle("[grid-template-rows:1fr]", !collapsed);
      content.classList.toggle("opacity-0", collapsed);
      content.classList.toggle("opacity-100", !collapsed);
      if (!animate)
        requestAnimationFrame(() =>
          content.classList.remove("!transition-none"),
        );
      toggleBtn.setAttribute("aria-expanded", String(!collapsed));
      if (caret) {
        caret.classList.toggle("-rotate-90", collapsed);
        caret.classList.toggle("rotate-0", !collapsed);
      }
      try {
        sessionStorage.setItem("pkg-banner-collapsed", String(collapsed));
      } catch (_) {}
    }
    if (toggleBtn) {
      try {
        const stored = sessionStorage.getItem("pkg-banner-collapsed");
        if (stored === "true") setCollapsed(true, false);
      } catch (_) {}
      toggleBtn.addEventListener("click", () => {
        const collapsed = toggleBtn.getAttribute("aria-expanded") === "true";
        setCollapsed(collapsed, true);
      });
    }
  </script>
  <script is:inline>
    const headings = Array.from(document.querySelectorAll("h2, h3, h4"));
    headings.forEach((heading) => {
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^\w\s]/g, "")
          .replace(/\s+/g, "-");
      }
    });
  </script>
  <script is:inline>
    const COPY_ICON =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
    const CHECK_ICON =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>';

    document.querySelectorAll("article pre").forEach((pre) => {
      const code = pre.querySelector("code");
      if (!code || pre.querySelector(".copy-code-button")) return;

      const button = document.createElement("button");
      button.type = "button";
      button.className = "copy-code-button";
      button.setAttribute("aria-label", "Copy code to clipboard");
      button.innerHTML = COPY_ICON;

      let timeout;
      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(code.innerText);
          button.classList.add("copied");
          button.innerHTML = CHECK_ICON;
          button.setAttribute("aria-label", "Copied");
          clearTimeout(timeout);
          timeout = setTimeout(() => {
            button.classList.remove("copied");
            button.innerHTML = COPY_ICON;
            button.setAttribute("aria-label", "Copy code to clipboard");
          }, 2000);
        } catch (_) {}
      });

      pre.appendChild(button);
    });
  </script>
</BaseLayout>
