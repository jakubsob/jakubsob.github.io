---
import BaseLayout from "./BaseLayout.astro";
import BlogPostJSONLD from "../components/features/BlogPostJSONLD.astro";
import FormattedDate from "../components/features/FormattedDate";
import { Section } from "@/components/ui/section";
import { Button } from "@/components/ui/button";
import { TagList } from "@/components/features/TagList";
import { Asterisk, ExternalLink } from "lucide-react";
import GetRoadmapButton from "@/components/features/GetRoadmapButton.astro";
import { getReadingTime } from "../utils/getReadingTime";
import TableOfContents from "../components/features/TableOfContents";
import PostList from "@/components/features/PostList";
import { getCollection } from "astro:content";
import { proseClasses } from "@/lib/prose";
import { ArrowLeft, ArrowRight } from "lucide-react";

// `trackContext` is only supplied by the /learn/[track]/[lesson] reading route.
// On the plain /blog route it is undefined, so no lesson navigation renders —
// a reader arriving cold via search/blog isn't pushed into a sequence.
// `canonicalURL` lets the lesson route point back at the canonical /blog page.
const { post, trackContext, canonicalURL } = Astro.props;
const readingTime = getReadingTime(post.body);
const { title, description, pubDate, updatedDate, tags } = post.data;
const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((post) => post.data.tags.some((tag) => tags.includes(tag)))
  .filter((post) => post.data.title !== title)
  .filter((post) => post.data.draft !== true)
  .filter((_, index) => index < 3);
---

<style is:global>
  /* Remove default quote marks from blockquotes */
  .prose blockquote p::before,
  .prose blockquote p::after {
    content: none !important;
  }
</style>

<BaseLayout
  {...post.data}
  ogType="article"
  image={`/blog/${post.slug}/og-image.png`}
  canonicalURL={canonicalURL}
>
  <BlogPostJSONLD slot="head" {...post.data} slug={post.slug} />
  <Section variant="dark" className="pt-14">
    <div
      class="w-full xl:max-w-screen-xl 2xl:max-w-[1400px] xl:mx-auto border-x px-4 grid grid-cols-1 lg:grid-cols-[1fr_65ch_1fr] gap-8"
    >
      <div class="lg:col-start-2">
        <article class={`mx-auto ${proseClasses} px-2`}>
          <header class="border-b pb-6">
            {
              trackContext && (
                <a
                  href={`/learn/${trackContext.track.id}/`}
                  class="not-prose group inline-flex items-center gap-2 text-xs uppercase tracking-wide text-muted-foreground hover:text-foreground transition-colors no-underline mb-2"
                >
                  <span>
                    Part of{" "}
                    <strong class="font-medium">
                      {trackContext.track.title}
                    </strong>
                  </span>
                  <span class="text-muted-foreground/50">·</span>
                  <span class="tabular-nums">
                    Lesson {trackContext.position} of {trackContext.total}
                  </span>
                </a>
              )
            }
            <h1 class="text-balance">{title}</h1>
            {
              description && (
                <p class="text-xl font-normal text-muted-foreground m-0">
                  {description}
                </p>
              )
            }
            <div
              class="flex flex-row flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted-foreground/60 uppercase"
            >
              <div>
                {pubDate && <FormattedDate date={pubDate} />}
                {
                  updatedDate && (
                    <div>
                      Last updated on <FormattedDate date={updatedDate} />
                    </div>
                  )
                }
              </div>
              <TagList tags={tags} linked={true} client:load />
              <span class="ml-auto tabular-nums">
                {readingTime}
              </span>
            </div>
          </header>
          <slot />
          {
            trackContext && (trackContext.prev || trackContext.next) && (
              <nav
                aria-label="Track navigation"
                class="not-prose pt-10 mt-10 bg-secondary"
              >
                <a
                  href={`/learn/${trackContext.track.id}/`}
                  class="block text-xs uppercase tracking-wide text-muted-foreground hover:text-foreground transition-colors no-underline mb-4"
                >
                  {trackContext.track.title} · Lesson {trackContext.position} of{" "}
                  {trackContext.total}
                </a>
                <div class="grid grid-cols-1 sm:grid-cols-2">
                  {trackContext.prev ? (
                    <a
                      href={`/learn/${trackContext.track.id}/${trackContext.prev.slug}/`}
                      class="group flex flex-col gap-1 border p-4 no-underline hover:bg-light transition-colors"
                    >
                      <span class="inline-flex items-center gap-1 text-xs uppercase tracking-wide text-muted-foreground">
                        <ArrowLeft className="size-[1em]" /> Previous
                      </span>
                      <span class="font-medium text-balance group-hover:text-primary transition-colors">
                        {trackContext.prev.post.data.title}
                      </span>
                    </a>
                  ) : (
                    <div />
                  )}
                  {trackContext.next && (
                    <a
                      href={`/learn/${trackContext.track.id}/${trackContext.next.slug}/`}
                      class="group flex flex-col gap-1 border p-4 no-underline hover:bg-light transition-colors sm:text-right"
                    >
                      <span class="inline-flex items-center gap-1 text-xs uppercase tracking-wide text-muted-foreground sm:justify-end">
                        Next <ArrowRight className="size-[1em]" />
                      </span>
                      <span class="font-medium text-balance group-hover:text-primary transition-colors">
                        {trackContext.next.post.data.title}
                      </span>
                    </a>
                  )}
                </div>
              </nav>
            )
          }
          <div
            class="flex flex-col md:flex-row gap-6 md:gap-12 justify-between py-24"
          >
            <div class="w-full">
              <GetRoadmapButton />
            </div>
            <div class="flex items-center justify-center text-muted">or</div>
            <a
              href="https://github.com/jakubsob/r-tests-gallery/issues/new/choose"
              target="_blank"
              class="flex items-center gap-2 no-underline w-full"
              rel="noopener noreferrer"
            >
              <Button
                variant="pill"
                shape="pill"
                className="flex-1 font-light h-auto"
              >
                <ExternalLink className="size-[1em]" />
                <div>Submit a content request</div>
              </Button>
            </a>
          </div>
        </article>
      </div>
      <div class="relative">
        <TableOfContents client:load />
      </div>
    </div>
  </Section>
  <Section variant="light">
    <div class="container mx-auto grid grid-cols-1 gap-2 max-w-[65ch]">
      <div class="py-24">
        <h2 class="text-2xl lg:text-3xl mb-6 flex items-center uppercase">
          <Asterisk className="size-[1em] block" />
          <span>You might also like</span>
        </h2>
        <PostList posts={posts} showControls={false} />
      </div>
    </div>
  </Section>
  <script is:inline>
    const headings = Array.from(document.querySelectorAll("h2, h3, h4"));
    headings.forEach((heading) => {
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^\w\s]/g, "")
          .replace(/\s+/g, "-");
      }
    });
  </script>
</BaseLayout>
