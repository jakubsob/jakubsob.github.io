---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";

interface Props {
  title: string;
  titleSEO?: string;
  description?: string;
  descriptionSEO?: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title: titlePrimary,
  titleSEO,
  description: descriptionPrimary,
  descriptionSEO,
  image = "/ogimg-home.png",
} = Astro.props;

const title = titleSEO || titlePrimary;
const description = descriptionSEO || descriptionPrimary;

const googleAnalyticsID = "G-735BLDHJRX";
const gtagUrl = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsID}`;
const shouldLoadAnalytics = import.meta.env.PROD;
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="webp" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />
  <slot />

  <link
    rel="alternate"
    type="application/rss+xml"
    title={title}
    href={new URL("rss-r.xml", Astro.site)}
  />

  <!-- MailerLite Universal -->
  <script is:inline>
    (function (w, d, e, u, f, l, n) {
      (w[f] =
        w[f] ||
        function () {
          (w[f].q = w[f].q || []).push(arguments);
        }),
        (l = d.createElement(e)),
        (l.async = 1),
        (l.src = u),
        (n = d.getElementsByTagName(e)[0]),
        n.parentNode.insertBefore(l, n);
    })(
      window,
      document,
      "script",
      "https://assets.mailerlite.com/js/universal.js",
      "ml"
    );
    ml("account", "1677606");
  </script>
  <!-- End MailerLite Universal -->

  <!-- Developer Easter egg -->
  <script is:inline>
    (function () {
      var msg = [
        "%c# jakubsob.github.io",
        "%c",
        "%c# Hey, you opened the console — fellow developer!",
        "%c# This site is built with Astro, React, and Tailwind.",
        "%c# Source: github.com/jakubsob/jakubsob.github.io",
        "%c#",
        "%c# If R testing is your thing, you're in the right place.",
      ].join("\n");
      var style = "color: #7dd3fc; font-family: monospace; font-size: 13px;";
      var muted = "color: #6b7280; font-family: monospace; font-size: 13px;";
      console.log(
        msg,
        style, muted, muted, muted, muted, muted, muted
      );
    })();
  </script>

  <!-- Follow.it  -->
  <meta name="follow.it-verification-code" content="UzA851QwnL0Gqry6AJNE" />

  <!-- Google Analytics -->
  {shouldLoadAnalytics && (
    <>
      <script is:inline async src={gtagUrl}></script>
      <script is:inline define:vars={{ googleAnalyticsID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", googleAnalyticsID);
      </script>
      <link rel="preconnect" href="https://www.googletagmanager.com/" />
    </>
  )}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
</head>
