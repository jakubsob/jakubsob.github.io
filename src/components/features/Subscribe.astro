---
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";
import "@/styles/mailerlite.css";
interface Props {
  variant: "waitlist" | "blog" | "roadmap";
}

const { variant: variantName = "blog" } = Astro.props as Props;

// Self-owned newsletter: the form POSTs to our Cloudflare Worker, which stores
// a pending subscriber in the private data repo and sends a double-opt-in
// email. `tags` records which lead magnet / interest the signup came from.
const API =
  import.meta.env.PUBLIC_NEWSLETTER_API ||
  "https://jakubsobolewski-newsletter.jakubsobolewski.workers.dev";

// Cloudflare Turnstile (bot protection). When the public sitekey is set, the
// widget renders and its token is sent to the Worker, which verifies it. Unset
// (e.g. local dev) → no widget and the Worker skips verification.
const TURNSTILE_SITEKEY = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || "";

const variants = {
  waitlist: {
    title: "Join waitlist",
    id: "waitlist",
    tags: ["waitlist"],
    confirmText: "Click the link inside to confirm your spot on the waitlist.",
  },
  blog: {
    title: "Subscribe",
    id: "blog",
    tags: ["blog"],
    confirmText: "Click the link inside to confirm your subscription.",
  },
  roadmap: {
    title: "Get The Roadmap",
    id: "roadmap",
    tags: ["roadmap"],
    confirmText: "Click the link inside to confirm and get the roadmap.",
  },
};
const variant = variants[variantName];
---

<div
  id={`subscribe-${variant.id}`}
  class={`ml-subscribe-form ml-subscribe-form-${variant.id} w-full mx-auto`}
>
  <div class="text-center">
    <div class="embedForm">
      <div class="row-form">
        <form
          class="ml-block-form w-full grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-0"
          novalidate
        >
          <div class="w-full">
            <Input
              aria-label="email"
              aria-required="true"
              type="email"
              className="w-full bg-background"
              name="email"
              placeholder="Email"
              required
            />
          </div>
          <div class="ml-form-embedSubmit">
            <Button
              type="submit"
              variant="primary"
              className="w-full rounded-none"
            >
              {variant.title || "Subscribe"}
            </Button>
          </div>
        </form>
        {
          TURNSTILE_SITEKEY && (
            <div
              class="cf-turnstile mt-3 flex justify-center"
              data-sitekey={TURNSTILE_SITEKEY}
              data-size="flexible"
              data-appearance="interaction-only"
            />
          )
        }
        <p class="row-error text-destructive text-sm mt-2" hidden></p>
      </div>
      <div
        class="ml-form-successBody row-success"
        role="status"
        aria-live="polite"
      >
        <div class="newsletter-console mt-6 mx-auto">
          <div class="nc-bar" aria-hidden="true">
            <span class="nc-dot"></span>
            <span class="nc-title font-mono">subscribe.R</span>
          </div>
          <div class="nc-body font-mono">
            <p class="nc-line nc-prompt" aria-hidden="true">
              <span class="nc-caret">&#10095;</span> subscribe(<span
                class="nc-email"></span>)
            </p>
            <p class="nc-line nc-info">
              &#8505; Confirmation email sent to your inbox.
            </p>
            <p class="nc-line nc-confirm">
              &#8594; {variant.confirmText}
            </p>
            <p class="nc-line nc-summary" aria-hidden="true">
              [ FAIL 0 | WARN 0 | SKIP 0 | <span class="nc-pass">PASS 1</span> ]
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    api: API,
    containerId: `subscribe-${variant.id}`,
    tags: variant.tags,
    turnstileSitekey: TURNSTILE_SITEKEY,
  }}
>
  (function () {
    const container = document.getElementById(containerId);
    if (!container) return;
    const form = container.querySelector("form");
    const errorEl = container.querySelector(".row-error");
    const formRow = container.querySelector(".row-form");
    const successRow = container.querySelector(".row-success");
    const button = container.querySelector("button[type=submit]");
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // Load the Turnstile script once per page; it auto-renders .cf-turnstile.
    if (turnstileSitekey && !window.__turnstileLoading) {
      window.__turnstileLoading = true;
      const s = document.createElement("script");
      s.src = "https://challenges.cloudflare.com/turnstile/v0/api.js";
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }

    function showError(message) {
      if (!errorEl) return;
      errorEl.textContent = message;
      errorEl.hidden = false;
    }

    function turnstileToken() {
      const el = container.querySelector('[name="cf-turnstile-response"]');
      return el ? el.value : "";
    }

    function resetTurnstile() {
      const widget = container.querySelector(".cf-turnstile");
      if (widget && window.turnstile) window.turnstile.reset(widget);
    }

    // "Print" the console lines in sequence via the Web Animations API.
    function printConsole() {
      const lines = successRow.querySelectorAll(".nc-line");
      if (prefersReduced) {
        lines.forEach((l) => (l.style.opacity = "1"));
        return;
      }
      const ease = "cubic-bezier(0.16, 1, 0.3, 1)";
      lines.forEach((line, i) => {
        const prompt = i === 0;
        const frames = prompt
          ? [
              { opacity: 0, clipPath: "inset(0 100% 0 0)" },
              { opacity: 1, clipPath: "inset(0 0 0 0)" },
            ]
          : [
              { opacity: 0, transform: "translateY(8px)" },
              { opacity: 1, transform: "translateY(0)" },
            ];
        line.animate(frames, {
          duration: prompt ? 380 : 320,
          delay: 60 + i * 170,
          easing: ease,
          fill: "forwards",
        });
      });
    }

    // Lift the form away, then reveal + print the success console.
    function revealSuccess(email) {
      const emailEcho = successRow.querySelector(".nc-email");
      if (emailEcho) emailEcho.textContent = '"' + email + '"';
      formRow.classList.add("is-leaving");
      const reveal = () => {
        formRow.style.display = "none";
        successRow.style.display = "block";
        printConsole();
      };
      if (prefersReduced) reveal();
      else setTimeout(reveal, 190);
    }

    form.addEventListener("submit", async function (event) {
      event.preventDefault();
      if (errorEl) errorEl.hidden = true;

      const email = (form.email.value || "").trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError("Please enter a valid email address.");
        return;
      }

      const token = turnstileToken();
      if (turnstileSitekey && !token) {
        showError("Please complete the verification and try again.");
        return;
      }

      button.disabled = true;
      button.setAttribute("aria-busy", "true");
      try {
        const res = await fetch(api + "/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, tags, source: "blog-form", token }),
        });
        if (!res.ok) throw new Error("Request failed");
        revealSuccess(email);
      } catch (err) {
        button.disabled = false;
        button.removeAttribute("aria-busy");
        resetTurnstile(); // token is single-use; get a fresh one for retry
        showError("Something went wrong. Please try again.");
      }
    });
  })();
</script>
