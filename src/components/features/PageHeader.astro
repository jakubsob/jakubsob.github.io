---
import { Animate } from "@/components/ui/animate";

interface Props {
  label: string;
  subtitle?: string;
}
const { label, subtitle } = Astro.props;
---

<header class="mb-12">
  <Animate>
    <p
      class="text-xs uppercase tracking-widest text-muted-foreground/60 font-medium mb-3"
    >
      {label}
    </p>
    <h1
      class="text-[clamp(2.5rem,5vw,5.5rem)] font-medium uppercase leading-[0.88] tracking-[-0.03em]"
    >
      {subtitle ?? label}
    </h1>
  </Animate>
</header>
