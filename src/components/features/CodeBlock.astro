---
import Code from "@/components/features/Code.astro";
import type { BundledLanguage } from "shiki";

type Variant = "default" | "destructive" | "success" | "neutral";

const variantBorder: Record<Variant, string> = {
  default: "hover:border-muted",
  destructive: "border-destructive/60",
  success: "border-success/60",
  neutral: "border-border/60",
};

interface Props {
  code: string;
  lang?: BundledLanguage;
  variant?: Variant;
}

const { code, lang = "text", variant = "default" } = Astro.props;
---

<div
  class={`code-block rounded-[var(--radius-surface)] border bg-card shadow-sm w-full overflow-hidden transition-colors ${variantBorder[variant]}`}
>
  <div class="flex items-center h-10 px-3 border-b border-border">
    <button
      class="copy-btn ml-auto text-xs text-muted-foreground border border-border px-2 py-0.5 rounded hover:bg-muted hover:text-foreground transition-colors"
    >
      Copy
    </button>
  </div>
  <Code
    code={code}
    lang={lang}
  />
</div>

<script>
  document.querySelectorAll<HTMLElement>(".code-block").forEach((block) => {
    const btn = block.querySelector<HTMLButtonElement>(".copy-btn");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const text = block.querySelector("code")?.innerText ?? "";
      await navigator.clipboard.writeText(text);
      btn.textContent = "Copied";
      setTimeout(() => { btn.textContent = "Copy"; }, 700);
    });
  });
</script>
