---
import type { CollectionEntry } from "astro:content";
import { Post } from "./Post";

interface Props {
  posts: CollectionEntry<"blog">[];
  slugs: string[];
}

const { posts, slugs } = Astro.props;

const featured = slugs
  .map((slug) => posts.find((p) => p.slug === slug))
  .filter(Boolean) as CollectionEntry<"blog">[];
---

{featured.length > 0 && (
  <div class="mb-12">
    <h2 class="text-sm uppercase tracking-widest text-muted-foreground mb-6">Featured</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {featured.map((post) => (
        <Post post={post} variant="featured" client:load />
      ))}
    </div>
  </div>
)}
