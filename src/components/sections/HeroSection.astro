---
import { Button } from "@/components/ui/button";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import { ArrowDown } from "lucide-react";

const splitLetters = (text: string) =>
  text
    .split("")
    .map((char) =>
      char === " "
        ? `<span class="hero-letter" aria-hidden="true">&nbsp;</span>`
        : `<span class="hero-letter" aria-hidden="true">${char}</span>`,
    )
    .join("");

const cols = Array.from({ length: 8 });
---

<Section variant="dark" size="full" id="hero">
  <div class="hero-grid h-[100svh] w-full relative overflow-hidden">
    <!-- Vertical column lines -->
    <div class="absolute inset-0 z-[1] pointer-events-none flex hero-cols">
      {cols.map(() => <div class="flex-1 border-r border-foreground/[0.07]" />)}
    </div>

    <!-- Spacer: absorbs height above text rows -->
    <div aria-hidden="true" class="col-span-8"></div>

    <!--
      h1 with display:contents — children become direct grid items.
      aria-label preserves semantics for screen readers.
    -->
    <h1
      aria-label="Building Quality By Testing"
      class="[display:contents] select-none"
    >
      <div
        class="col-span-8 flex items-end relative z-10 px-6 md:px-12 lg:px-16"
      >
        <Animate variant="header" className="motion-delay-[200ms]">
          <span
            class="hero-line block text-[clamp(3.5rem,16vw,14rem)] font-bold uppercase leading-[0.88] tracking-[-0.04em] whitespace-nowrap"
            set:html={splitLetters("Building")}
          />
        </Animate>
      </div>
      <div
        class="col-span-8 flex items-end relative z-10 px-6 md:px-12 lg:px-16"
      >
        <Animate variant="header" className="motion-delay-[300ms]">
          <span
            class="hero-line block text-[clamp(3.5rem,16vw,14rem)] font-bold uppercase leading-[0.88] tracking-[-0.04em] whitespace-nowrap"
            set:html={splitLetters("Quality")}
          />
        </Animate>
      </div>
      <div
        class="col-span-8 flex items-end relative z-10 px-6 md:px-12 lg:px-16"
      >
        <Animate variant="header" className="motion-delay-[400ms]">
          <span
            class="hero-line block text-[clamp(3.5rem,16vw,14rem)] font-bold uppercase leading-[0.88] tracking-[-0.04em] whitespace-nowrap text-primary"
            set:html={splitLetters("By Testing")}
          />
        </Animate>
      </div>
    </h1>

    <!-- Description: full-width on mobile, cols 1-5 on lg -->
    <div
      class="col-span-8 lg:col-span-5 flex items-start relative z-10 pl-6 md:pl-12 lg:pl-16"
    >
      <Animate variant="header" className="motion-delay-[550ms]">
        <p
          class="text-foreground/70 text-base md:text-lg font-serif font-light leading-relaxed max-w-[44ch]"
        >
          I'm Jakub. Practical articles and open-source tools for developers who
          want to build software they trust.
        </p>
      </Animate>
    </div>

    <!-- Buttons: full-width on mobile, cols 6-8 on lg (same row as description) -->
    <div
      class="col-span-8 lg:col-span-3 flex items-start relative z-10 pr-6 pl-6 lg:pl-0 lg:justify-end"
    >
      <div class="flex flex-row gap-3 shrink-0">
        <Animate variant="expand" className="motion-delay-[650ms]">
          <a href="/course" class="block">
            <Button
              variant="primary"
              size="xl"
              shape="pill"
              className="uppercase tracking-wide text-sm md:text-base font-bold whitespace-nowrap"
            >
              <span class="sm:hidden">Testing course</span>
              <span class="hidden sm:inline">Take the testing course</span>
            </Button>
          </a>
        </Animate>
        <Animate variant="expand" className="motion-delay-[750ms]">
          <a href="/get-roadmap" class="block">
            <Button size="xl" variant="link">
              <span class="sm:hidden">Roadmap</span>
              <span class="hidden sm:inline">Get Roadmap</span>
            </Button>
          </a>
        </Animate>
      </div>
    </div>
  </div>

  <Animate variant="header" className="motion-delay-[1000ms]">
    <a
      href="#blog"
      aria-label="Scroll to blog section"
      class="cursor-pointer text-foreground/40 border-foreground/40 absolute bottom-0 left-1/2 -translate-x-1/2 size-11 mb-2 rounded-full border-2 animate-pulse hidden md:flex items-center justify-center"
    >
      <ArrowDown className="block size-6" aria-hidden="true" />
    </a>
  </Animate>
</Section>

<style>
  .hero-grid {
    --row-h: calc(0.88 * clamp(3.5rem, 16vw, 14rem));
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: 1fr repeat(5, var(--row-h));
    background-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.07) 1px,
      transparent 1px
    );
    background-size: 100% var(--row-h);
    background-position: 0 bottom;
    animation: grid-fade-in 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  @media (max-width: 639px) {
    .hero-grid {
      grid-template-rows: 1fr repeat(3, var(--row-h)) auto auto;
      padding-bottom: 1.5rem;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .hero-grid {
      padding-bottom: var(--row-h);
    }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-rows: 1fr repeat(4, var(--row-h));
    }
  }

  .hero-cols {
    animation: grid-fade-in 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  @keyframes grid-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Progressive enhancement: precise cap-height trim where supported (Chrome) */
  @supports (text-box-trim: trim-end) {
    .hero-line {
      text-box-trim: trim-end;
      text-box-edge: cap alphabetic;
    }
  }

  :global(.hero-letter) {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(.hero-letter:hover) {
    transform: translateY(-10px);
  }

  :global(.dark) .hero-grid {
    background-image: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.08) 1px,
      transparent 1px
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-grid,
    .hero-cols {
      animation: none;
    }
    :global(.hero-letter) {
      transition: none;
    }
  }
</style>
