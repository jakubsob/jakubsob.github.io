---
import { Button } from "@/components/ui/button";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import Notebook from "@/components/ui/notebook/Notebook.astro";

const splitLetters = (text: string) =>
  text
    .split("")
    .map((char) =>
      char === " "
        ? `<span class="hero-letter" aria-hidden="true">&nbsp;</span>`
        : `<span class="hero-letter" aria-hidden="true">${char}</span>`,
    )
    .join("");
---

<Section variant="dark" size="full" id="hero">
  <Notebook
    lines="both"
    rowAnchor="bottom"
    rowH="calc(0.88 * clamp(3.5rem, 16vw, 14rem))"
    cellGap="0"
    class="hero-notebook h-full overflow-hidden"
  >
    <!--
      h1 with display:contents — children become direct grid items so each
      text line lands in its own row, while the h1 keeps its semantics for
      assistive tech.
    -->
    <h1
      aria-label="Building Quality By Testing"
      class="[display:contents] select-none"
    >
      <div class="hero-line-cell col-[1/-1] row-start-[var(--hero-row-build)]">
        <Animate variant="header" className="motion-delay-[200ms]">
          <span class="hero-line" set:html={splitLetters("Building")} />
        </Animate>
      </div>
      <div
        class="hero-line-cell col-[1/-1] row-start-[var(--hero-row-quality)]"
      >
        <Animate variant="header" className="motion-delay-[300ms]">
          <span class="hero-line" set:html={splitLetters("Quality")} />
        </Animate>
      </div>
      <div
        class="hero-line-cell col-[1/-1] row-start-[var(--hero-row-by-testing)]"
      >
        <Animate variant="header" className="motion-delay-[400ms]">
          <span
            class="hero-line text-primary"
            set:html={splitLetters("By Testing")}
          />
        </Animate>
      </div>
    </h1>

    <!-- Description: full-width on small, cols 1-7 at lg (same row as buttons) -->
    <div
      class="col-[1/-1] lg:col-[1/8] row-start-[var(--hero-row-desc)] flex items-start relative z-10 pl-4"
    >
      <Animate variant="header" className="motion-delay-[550ms]">
        <p
          class="text-foreground/70 text-base md:text-lg font-serif font-light leading-relaxed max-w-[60ch]"
        >
          I'm Jakub Sobolewski. <br />
          I build the open-source tools <br />
          and write the playbooks that define how R and Shiny teams test.
        </p>
      </Animate>
    </div>

    <!-- Buttons: full-width on small (own row), cols 8-12 at lg (same row as desc) -->
    <div
      class="col-[1/-1] lg:col-[8/-1] row-start-[var(--hero-row-buttons)] lg:row-start-[var(--hero-row-desc)] flex items-start relative z-10 px-4 md:px-6 lg:px-8 lg:justify-end"
    >
      <div class="flex flex-row gap-3 shrink-0">
        <Animate variant="expand" className="motion-delay-[650ms]">
          <a href="/get-roadmap" class="block">
            <Button
              variant="primary"
              size="xl"
              shape="pill"
              className="uppercase tracking-wide text-sm md:text-base font-bold whitespace-nowrap"
            >
              <span class="sm:hidden">Roadmap</span>
              <span class="hidden sm:inline">Get Roadmap</span>
            </Button>
          </a>
        </Animate>
        <Animate variant="expand" className="motion-delay-[750ms]">
          <a href="https://courses.jakubsobolewski.com" class="block">
            <Button size="xl" variant="link">
              <span class="sm:hidden">Testing course</span>
              <span class="hidden sm:inline">Join testing course waitlist</span>
            </Button>
          </a>
        </Animate>
      </div>
    </div>
  </Notebook>
</Section>

<style>
  /*
   * Row assignments per breakpoint. Rows are counted from the TOP of the
   * inner grid, but content is anchored to the bottom via Notebook's
   * `rowAnchor="bottom"` (which sets align-content: end). What actually
   * controls visual placement is the order of the three text lines + the
   * desc/buttons row stacked together at the bottom of the section.
   *
   * Mobile/tablet: 5 rows (3 text + desc + buttons stacked).
   * Desktop (lg+):  4 rows (3 text + desc/buttons sharing one row).
   */
  .hero-notebook {
    --hero-row-build: 1;
    --hero-row-quality: 2;
    --hero-row-by-testing: 3;
    --hero-row-desc: 4;
    --hero-row-buttons: 5;
  }

  @media (min-width: 1024px) {
    .hero-notebook {
      --hero-row-buttons: 4; /* same row as desc */
    }
  }

  /* Each hero text line is a grid cell exactly --nb-row-h tall. The text
     itself uses `align-items: end` so the glyph baseline sits on the bottom
     edge of the cell — which is also where the horizontal line is painted. */
  .hero-line-cell {
    display: flex;
    align-items: end;
    justify-content: flex-start;
    position: relative;
    z-index: 10;
    overflow: visible;
  }

  .hero-line {
    display: block;
    font-size: clamp(3.5rem, 16vw, 14rem);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 0.88;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  /* Progressive enhancement: precise cap-height trim where supported. */
  @supports (text-box-trim: trim-end) {
    .hero-line {
      text-box-trim: trim-end;
      text-box-edge: cap alphabetic;
    }
  }

  :global(.hero-letter) {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(.hero-letter:hover) {
    transform: translateY(-10px);
  }

  /* Fade-in animation on the notebook itself (lines + content). */
  .hero-notebook {
    animation: hero-fade-in 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  @keyframes hero-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-notebook {
      animation: none;
    }
    :global(.hero-letter) {
      transition: none;
    }
  }
</style>
