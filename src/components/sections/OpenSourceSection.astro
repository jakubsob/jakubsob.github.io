---
import { Code } from "astro:components";
import { Button } from "@/components/ui/button";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import { CodeFrame } from "@/components/ui/code-frame";
import { EyebrowLabel } from "@/components/ui/eyebrow-label";
import SectionHeading from "@/components/ui/section-heading.astro";
import { CircleArrowRight } from "lucide-react";
import { transformerNotationDiff } from "@shikijs/transformers";
---

<style>
  /* github-light tokens */
  :root {
    --corr-bg: #ffffff;
    --corr-text: #24292f;
    --corr-kw-struct: #0550ae;
    --corr-kw-step: #cf222e;
    --corr-string: #0a3069;
    --corr-fn: #8250df;
    --corr-param: #953800;
  }
  /* github-dark tokens */
  :root.dark {
    --corr-bg: #0d1117;
    --corr-text: #e6edf3;
    --corr-kw-struct: #7ee787;
    --corr-kw-step: #ff7b72;
    --corr-string: #a5d6ff;
    --corr-fn: #d2a8ff;
    --corr-param: #ffa657;
  }
  .corr-pre-bg { background: var(--corr-bg); color: var(--corr-text); }
  .corr-kw-struct { color: var(--corr-kw-struct); }
  .corr-kw-step { color: var(--corr-kw-step); }
  .corr-text { color: var(--corr-text); }
  .corr-string { color: var(--corr-string); }
  .corr-fn { color: var(--corr-fn); }
  .corr-param { color: var(--corr-param); }
</style>

<Section id="opensource" size="fit" variant="dark">
  <SectionHeading title="My Open Source" />
  <div class="py-20 my-10">
    <div class="container">
      <div class="pb-16">
        <Animate>
          <div class="flex items-start gap-6">
            <div class="size-[120px] flex-shrink-0">
              <img
                class="w-full h-full object-contain"
                src="https://raw.githubusercontent.com/jakubsob/cucumber/main/man/figures/logo.png"
                alt="cucumber logo"
                width="120"
                height="120"
              />
            </div>
            <div>
              <a
                href="https://github.com/jakubsob/cucumber"
                class="hover:underline"
              >
                <h3 class="text-clamp-sm uppercase leading-none">Cucumber</h3>
              </a>
              <p class="text-muted-foreground mt-3 max-w-[55ch]">
                Write behavior specifications in plain English, implement them
                as R functions, and run them as tests. Requirements stay in
                sync with the code because they are the code.
              </p>
            </div>
          </div>
        </Animate>
      </div>

      <div class="space-y-0">
        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pb-16 border-b border-foreground/10"
          >
            <div>
              <EyebrowLabel>
                <span class="text-destructive mr-1">✗</span>comments as specs
              </EyebrowLabel>
              <p
                class="text-sm text-muted-foreground leading-relaxed max-w-[36ch]"
              >
                Comments encode intent but not procedure. They don't separate
                precondition from action from outcome. They can't be run, so
                they drift — and a stale comment is worse than no comment.
              </p>
            </div>
            <CodeFrame variant="destructive">
              <Code
                themes={{
                  light: "github-light",
                  dark: "github-dark",
                }}
                lang="r"
                code={`test_that("sales trend works", {
  # sales data is available
  # check the plot for Electronics
  # make sure it looks right

  result <- get_sales_trend("Electronics")
  expect_s3_class(result, "ggplot")
})`}
              />
            </CodeFrame>
          </div>
        </Animate>

        <div
          id="cucumber-corr"
          class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start py-12 border-b border-foreground/10"
        >
          <!-- Left: Gherkin spec -->
          <div>
            <EyebrowLabel>
              <span class="text-success mr-1">✓</span>the specification
            </EyebrowLabel>
            <p class="text-sm text-muted-foreground leading-relaxed max-w-[42ch] mb-6">
              Gherkin forces you to think in procedure: what state is required,
              what action is taken, what outcome is observable. Vague intent
              doesn't survive the structure.
            </p>
            <div class="rounded-lg border border-success/60 overflow-hidden">
              <pre class="p-4 m-0 overflow-x-auto text-[0.82rem] leading-[1.65]" class="corr-pre-bg" style="font-family:ui-monospace,monospace"><span class="corr-pre corr-preamble" style="display:block;opacity:0;transition:opacity 0.35s ease-out"><span class="corr-kw-struct">Feature</span><span class="corr-text">: Sales Trends</span></span><span class="corr-pre corr-preamble" style="display:block;opacity:0;transition:opacity 0.35s ease-out"> </span><span class="corr-pre corr-preamble" style="display:block;opacity:0;transition:opacity 0.35s ease-out"><span class="corr-text">  </span><span class="corr-kw-struct">Scenario</span><span class="corr-text">: User views trend for a category</span></span><span class="corr-pre corr-step rounded-sm" data-step="1" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out"><span class="corr-text">    </span><span class="corr-kw-step" style="font-weight:600">Given</span><span class="corr-text"> the sales data is loaded</span></span><span class="corr-pre corr-step rounded-sm" data-step="2" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out"><span class="corr-text">    </span><span class="corr-kw-step" style="font-weight:600">When</span><span class="corr-text"> the user views the trend for </span><span class="corr-string">"Electronics"</span></span><span class="corr-pre corr-step rounded-sm" data-step="3" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out"><span class="corr-text">    </span><span class="corr-kw-step" style="font-weight:600">Then</span><span class="corr-text"> the sales trend plot for </span><span class="corr-string">"Electronics"</span><span class="corr-text"> is shown</span></span></pre>
            </div>
          </div>

          <!-- Right: R implementation -->
          <div>
            <EyebrowLabel>
              <span class="text-success mr-1">✓</span>the implementation
            </EyebrowLabel>
            <p class="text-sm text-muted-foreground leading-relaxed max-w-[36ch] mb-6">
              Each line of the spec maps to one R function. The English phrase
              becomes the function signature — the same words, now executable.
            </p>
            <div class="rounded-lg border border-success/60 overflow-hidden">
              <pre class="p-4 m-0 overflow-x-auto text-[0.82rem] leading-[1.65]" class="corr-pre-bg" style="font-family:ui-monospace,monospace"><span class="corr-pre corr-block rounded-sm" data-step="1" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out"><span class="corr-fn">given</span><span class="corr-text">(</span><span class="corr-string">"the sales data is loaded"</span><span class="corr-text">, </span><span class="corr-kw-step">function</span><span class="corr-text">(context) {</span>
<span class="corr-text">  context</span><span class="corr-text">$</span><span class="corr-text">data </span><span class="corr-text">&lt;-</span><span class="corr-text"> </span><span class="corr-fn">load_sales_data</span><span class="corr-text">()</span>
<span class="corr-text">})</span></span><span class="corr-pre corr-block rounded-sm" data-step="2" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out">
<span class="corr-fn">when</span><span class="corr-text">(</span><span class="corr-string">"the user views the trend for </span><span class="corr-param">&#123;string&#125;</span><span class="corr-string">"</span><span class="corr-text">, </span><span class="corr-kw-step">function</span><span class="corr-text">(category, context) {</span>
<span class="corr-text">  context$plot </span><span class="corr-text">&lt;-</span><span class="corr-text"> </span><span class="corr-fn">get_sales_trend</span><span class="corr-text">(context$data, category)</span>
<span class="corr-text">})</span></span><span class="corr-pre corr-block rounded-sm" data-step="3" style="display:block;opacity:0;transition:opacity 0.35s ease-out,background-color 0.1s ease-out">
<span class="corr-fn">then</span><span class="corr-text">(</span><span class="corr-string">"the sales trend plot for </span><span class="corr-param">&#123;string&#125;</span><span class="corr-string"> is shown"</span><span class="corr-text">, </span><span class="corr-kw-step">function</span><span class="corr-text">(category, context) {</span>
<span class="corr-text">  </span><span class="corr-fn">expect_s3_class</span><span class="corr-text">(context$plot, </span><span class="corr-string">"ggplot"</span><span class="corr-text">)</span>
<span class="corr-text">  </span><span class="corr-fn">expect_equal</span><span class="corr-text">(context$plot$labels$title, category)</span>
<span class="corr-text">})</span></span></pre>
            </div>
          </div>
        </div>

        <Animate>
          <div class="py-12">
            <EyebrowLabel>
              <span class="text-success mr-1">✓</span>verification
            </EyebrowLabel>
            <CodeFrame variant="success">
              <Code
                themes={{
                  light: "github-light",
                  dark: "github-dark",
                }}
                lang="r"
                code={`> cucumber::test()
#> ✔ | F W  S  OK | Context
#> ✔ |          1 | Feature: Sales Trends
#>
#> ══ Results ═══════════════════════════════════════════════════
#> [ FAIL 0 | WARN 0 | SKIP 0 | PASS 1 ]`}
              />
            </CodeFrame>
          </div>
        </Animate>
      </div>

      <div class="text-center pt-4 pb-4">
        <a href="https://jakubsobolewski.com/cucumber/" target="_blank">
          <Button
            size="xl"
            className="text-2xl motion-preset-oscillate-sm motion-paused hover:motion-running"
            variant="pill"
            shape="pill"
          >
            Try it out!
            <CircleArrowRight className="inline-block size-[1.5em] ml-2" />
          </Button>
        </a>
      </div>
    </div>
    <div class="container pt-24 mt-24 border-t border-foreground/10">
      <div class="pb-16">
        <Animate>
          <div class="flex items-start gap-6">
            <div class="size-[120px] flex-shrink-0">
              <img
                class="w-full h-full object-contain"
                src="https://raw.githubusercontent.com/jakubsob/muttest/main/man/figures/logo.png"
                alt="muttest logo"
                width="120"
                height="120"
              />
            </div>
            <div>
              <a
                href="https://github.com/jakubsob/muttest"
                class="hover:underline"
              >
                <h3 class="text-clamp-sm uppercase leading-none">Muttest</h3>
              </a>
              <p class="text-muted-foreground mt-3 max-w-[55ch]">
                Mutation testing for R. Introduces small changes to your
                source code and checks whether your tests catch them. Reveals
                gaps that code coverage misses.
              </p>
            </div>
          </div>
        </Animate>
      </div>

      <div class="space-y-0">
        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pb-16 border-b border-foreground/10"
          >
            <div>
              <EyebrowLabel>the code</EyebrowLabel>
              <p
                class="text-sm text-muted-foreground leading-relaxed max-w-[36ch]"
              >
                A simple boundary check. Two tests cover adults and minors —
                but never the edge.
              </p>
            </div>
            <div class="text-sm">
              <Code
                themes={{
                  light: "github-light",
                  dark: "github-dark",
                }}
                lang="r"
                code={`# R/is_adult.R
is_adult <- function(age) {
  age >= 18
}`}
              />
            </div>
          </div>
        </Animate>

        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pb-12 pt-12 border-b border-foreground/10"
          >
            <div>
              <EyebrowLabel>mutation score</EyebrowLabel>
              <div
                class="text-[clamp(5rem,12vw,9rem)] font-light leading-none tabular-nums text-destructive js-count-up"
                data-target="50"
              >
                0%
              </div>
              <p
                class="text-muted-foreground mt-4 text-sm leading-relaxed max-w-[36ch]"
              >
                The <code class="font-mono text-xs">{">"} 18</code> mutant survived.
                Boundary value 18 is never tested — your suite can't tell <code
                  class="font-mono text-xs">{">="}</code
                > from <code class="font-mono text-xs">{">"}</code>.
              </p>
            </div>
            <div class="text-sm">
              <EyebrowLabel>
                <span class="text-destructive mr-1">✗</span>the tests
              </EyebrowLabel>
              <CodeFrame variant="destructive">
                <Code
                  themes={{
                    light: "github-light",
                    dark: "github-dark",
                  }}
                  lang="r"
                  code={`test_that("is_adult returns TRUE for adults", {
  expect_true(is_adult(25))  # passes even with age > 18
})

test_that("is_adult returns FALSE for minors", {
  expect_false(is_adult(10))  # passes even with age > 18
})`}
                />
              </CodeFrame>
            </div>
          </div>
        </Animate>

        <Animate>
          <div class="py-12 border-b border-foreground/10">
            <EyebrowLabel>run mutation testing</EyebrowLabel>
            <CodeFrame variant="destructive">
              <Code
                themes={{
                  light: "github-light",
                  dark: "github-dark",
                }}
                lang="r"
                code={`> muttest::muttest(plan)
#> ℹ Mutation Testing
#>   |   K |   S |   E |   T |   % | Mutator  | File
#> ✔ |   1 |   0 |   0 |   1 | 100 | >= → <=  | is_adult.R
#> x |   1 |   1 |   0 |   2 |  50 | >= → >   | is_adult.R
#>
#> ── Survived Mutants ─────────────────────────────────────────────────────────
#> is_adult.R  >= → >
#>   2-   age >= 18
#>   2+   age > 18
#>
#> ── Results ──────────────────────────────────────────────────────────────────
#> [ KILLED 1 | SURVIVED 1 | ERRORS 0 | TOTAL 2 | SCORE 50.0% ]`}
              />
            </CodeFrame>
          </div>
        </Animate>

        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pt-12"
          >
            <div>
              <EyebrowLabel>after the fix</EyebrowLabel>
              <div
                class="text-[clamp(5rem,12vw,9rem)] font-light leading-none tabular-nums text-ocean-green-400 js-count-up"
                data-target="100"
              >
                0%
              </div>
              <p
                class="text-muted-foreground mt-4 text-sm leading-relaxed max-w-[36ch]"
              >
                Every mutation triggers a failure. Adding the boundary test
                kills the survivor.
              </p>
            </div>
            <div class="text-sm">
              <EyebrowLabel>
                <span class="text-success mr-1">✓</span>the fix
              </EyebrowLabel>
              <CodeFrame variant="success">
                <Code
                  themes={{
                    light: "github-light",
                    dark: "github-dark",
                  }}
                  lang="r"
                  transformers={[transformerNotationDiff()]}
                  code={`test_that("is_adult returns TRUE for adults", {
  expect_true(is_adult(25))
})

test_that("is_adult returns FALSE for minors", {
  expect_false(is_adult(10))
})

test_that("is_adult is TRUE at the boundary", { # [!code ++]
  expect_true(is_adult(18))  # kills >= → > # [!code ++]
}) # [!code ++]`}
                />
              </CodeFrame>
            </div>
          </div>
        </Animate>
      </div>

      <div class="text-center pt-16 pb-4">
        <a href="https://jakubsobolewski.com/muttest/" target="_blank">
          <Button
            size="xl"
            className="text-2xl motion-preset-oscillate-sm motion-paused hover:motion-running"
            variant="pill"
            shape="pill"
          >
            Patch the gaps in your tests
            <CircleArrowRight className="inline-block size-[1.5em] ml-2" />
          </Button>
        </a>
      </div>
    </div>
  </div>
</Section>

<script>
  function animateCount(el: HTMLElement, target: number, duration: number) {
    const start = performance.now();
    const update = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // ease-out-quart
      const eased = 1 - Math.pow(1 - progress, 4);
      el.textContent = Math.round(eased * target) + "%";
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target ?? "0", 10);
          animateCount(el, target, 1200);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll<HTMLElement>(".js-count-up").forEach((el) => {
    observer.observe(el);
  });
</script>

<script>
  const HIGHLIGHT_COLOR = "oklch(72% 0.08 145 / 0.18)";
  const STEP_DELAY = 600;
  const PREAMBLE_DELAY = 200;

  function flash(elements: NodeListOf<Element>) {
    elements.forEach((el) => {
      (el as HTMLElement).style.backgroundColor = HIGHLIGHT_COLOR;
      setTimeout(() => {
        (el as HTMLElement).style.backgroundColor = "transparent";
      }, STEP_DELAY);
    });
  }

  function runCucumberAnim(container: HTMLElement) {
    const preambles = container.querySelectorAll<HTMLElement>(".corr-preamble");
    const steps = [1, 2, 3];

    preambles.forEach((el) => {
      el.style.opacity = "1";
    });

    steps.forEach((step, i) => {
      setTimeout(() => {
        const leftEl = container.querySelector<HTMLElement>(`.corr-step[data-step="${step}"]`);
        const rightEl = container.querySelector<HTMLElement>(`.corr-block[data-step="${step}"]`);
        if (leftEl) leftEl.style.opacity = "1";
        if (rightEl) rightEl.style.opacity = "1";
        const paired = container.querySelectorAll(`[data-step="${step}"]`);
        flash(paired);
      }, PREAMBLE_DELAY + (i + 1) * STEP_DELAY);
    });
  }

  const corrContainer = document.getElementById("cucumber-corr");
  if (corrContainer) {
    const corrObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runCucumberAnim(entry.target as HTMLElement);
            corrObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    corrObserver.observe(corrContainer);
  }
</script>
