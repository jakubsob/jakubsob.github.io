---
import Code from "@/components/features/Code.astro";
import { Button } from "@/components/ui/button";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import { Card } from "@/components/ui/card";
import { EyebrowLabel } from "@/components/ui/eyebrow-label";
import SectionHeading from "@/components/ui/section-heading.astro";
import { CircleArrowRight } from "lucide-react";
import { transformerNotationDiff } from "@shikijs/transformers";
import { transformerStepAnimation } from "@/lib/transformerStepAnimation";
---

<Section id="opensource" size="fit" variant="light">
  <SectionHeading title="My Open Source" />
  <div class="container pt-4 pb-16">
    <div class="pb-12">
      <Animate>
        <div class="flex items-start gap-6" id="cucumber-header">
          <div class="size-[120px] flex-shrink-0">
            <img
              class="w-full h-full object-contain"
              src="https://raw.githubusercontent.com/jakubsob/cucumber/main/man/figures/logo.png"
              alt="cucumber logo"
              width="120"
              height="120"
            />
          </div>
          <div>
            <a
              href="https://github.com/jakubsob/cucumber"
              class="hover:underline"
            >
              <h3 class="text-clamp-sm uppercase leading-none">Cucumber</h3>
            </a>
            <p class="text-muted-foreground mt-3 max-w-[55ch]">
              Write behavior specifications in plain English, implement them as
              R functions, and run them as tests. Requirements stay in sync with
              the code because they are the code.
            </p>
          </div>
        </div>
      </Animate>
    </div>

    <div>
      <Animate>
        <div
          class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pb-16"
        >
          <div>
            <EyebrowLabel>
              <span class="text-destructive mr-1">✗</span>comments as specs
            </EyebrowLabel>
            <p
              class="text-sm text-muted-foreground leading-relaxed max-w-[36ch]"
            >
              Comments encode intent but not procedure. They don't separate
              precondition from action from outcome. They can't be run, so they
              drift — and a stale comment is worse than no comment.
            </p>
          </div>
          <Card variant="destructive">
            <Code
              lang="r"
              code={`test_that("sales trend works", {
  # sales data is available
  # check the plot for Electronics
  # make sure it looks right

  result <- get_sales_trend("Electronics")
  expect_s3_class(result, "ggplot")
})`}
            />
          </Card>
        </div>
      </Animate>
    </div>
  </div>

  <div class="bg-secondary py-16 js-strike-reveal select-none">
    <div class="container">
      <div class="relative inline-block">
        <span
          class="js-strike-text block uppercase text-[clamp(2rem,7vw,5rem)] font-bold leading-tight text-destructive/60"
        >
          Comments and docs
          <span
            class="js-strike-line absolute left-0 top-[55%] h-[4px] w-0 bg-destructive rounded-full"
            aria-hidden="true"></span>
        </span>
      </div>
      <div
        class="js-strike-result block uppercase text-[clamp(2rem,7vw,5rem)] font-bold leading-tight text-success opacity-0 translate-y-4 transition-none"
      >
        Executable specifications
      </div>
    </div>
  </div>

  <div class="container">
    <div>
      <div
        id="cucumber-corr"
        data-step-animate
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start py-16 border-b border-foreground/10"
      >
        <!-- Left: Gherkin spec -->
        <div>
          <EyebrowLabel>
            <span class="text-success mr-1">✓</span>the specification
          </EyebrowLabel>
          <p
            class="text-sm text-muted-foreground leading-relaxed max-w-[42ch] mb-6"
          >
            Gherkin forces you to think in procedure: what state is required,
            what action is taken, what outcome is observable. Vague intent
            doesn't survive the structure.
          </p>
          <Card variant="success">
            <Code
              lang="gherkin"
              transformers={[transformerStepAnimation()]}
              code={`Feature: Sales Trends

  Scenario: User views trend for a category
    Given the sales data is loaded # [!code step:1]
    When the user views the trend for "Electronics" # [!code step:2]
    Then the sales trend plot for "Electronics" is shown # [!code step:3]`}
            />
          </Card>
        </div>

        <!-- Right: R implementation -->
        <div>
          <EyebrowLabel>
            <span class="text-success mr-1">✓</span>the implementation
          </EyebrowLabel>
          <p
            class="text-sm text-muted-foreground leading-relaxed max-w-[36ch] mb-6"
          >
            Each line of the spec maps to one R function. The English phrase
            becomes the function signature — the same words, now executable.
          </p>
          <Card variant="success">
            <Code
              lang="r"
              transformers={[transformerStepAnimation()]}
              code={`given("the sales data is loaded", function(context) { # [!code step:1]
  context$data <- load_sales_data() # [!code step:1]
}) # [!code step:1]

when("the user views the trend for {string}", function(category, context) { # [!code step:2]
  context$plot <- get_sales_trend(context$data, category) # [!code step:2]
}) # [!code step:2]

then("the sales trend plot for {string} is shown", function(category, context) { # [!code step:3]
  expect_s3_class(context$plot, "ggplot") # [!code step:3]
  expect_equal(context$plot$labels$title, category) # [!code step:3]
}) # [!code step:3]`}
            />
          </Card>
        </div>
      </div>

      <Animate>
        <div class="pt-8 pb-12">
          <EyebrowLabel>
            <span class="text-success mr-1">✓</span>verification
          </EyebrowLabel>
          <Card variant="success">
            <Code
              lang="r"
              code={`> cucumber::test()
#> ✔ | F W  S  OK | Context
#> ✔ |          1 | Feature: Sales Trends
#>
#> ══ Results ═══════════════════════════════════════════════════
#> [ FAIL 0 | WARN 0 | SKIP 0 | PASS 1 ]`}
            />
          </Card>
        </div>
      </Animate>
    </div>

    <div class="pt-6 pb-12">
      <a href="https://jakubsobolewski.com/cucumber/" target="_blank">
        <Button size="xl" className="text-2xl" variant="pill" shape="pill">
          Try it out!
          <CircleArrowRight className="inline-block size-[1.5em] ml-2" />
        </Button>
      </a>
    </div>
  </div>
  <div class="bg-background mt-16">
    <div class="container">
      <div class="pt-12 pb-16">
        <Animate>
          <div class="flex items-start gap-6">
            <div class="size-[120px] flex-shrink-0">
              <img
                class="w-full h-full object-contain"
                src="https://raw.githubusercontent.com/jakubsob/muttest/main/man/figures/logo.png"
                alt="muttest logo"
                width="120"
                height="120"
              />
            </div>
            <div>
              <a
                href="https://github.com/jakubsob/muttest"
                class="hover:underline"
              >
                <h3 class="text-clamp-sm uppercase leading-none">Muttest</h3>
              </a>
              <p class="text-muted-foreground mt-3 max-w-[55ch]">
                Mutation testing for R. Introduces small changes to your source
                code and checks whether your tests catch them. Reveals gaps that
                code coverage misses.
              </p>
            </div>
          </div>
        </Animate>
      </div>
      <div>
        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pb-10 border-b border-foreground/10"
          >
            <div>
              <EyebrowLabel>the code</EyebrowLabel>
              <p
                class="text-sm text-muted-foreground leading-relaxed max-w-[36ch]"
              >
                A simple boundary check. Two tests cover adults and minors — but
                never the edge.
              </p>
            </div>
            <Card>
              <Code
                lang="r"
                code={`# R/is_adult.R
is_adult <- function(age) {
  age >= 18
}`}
              />
            </Card>
          </div>
        </Animate>

        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start py-10 border-b border-foreground/10"
          >
            <div>
              <EyebrowLabel>mutation score</EyebrowLabel>
              <div
                class="text-[clamp(5rem,12vw,9rem)] font-bold leading-none tabular-nums text-destructive js-count-up"
                data-target="50"
              >
                0%
              </div>
              <p
                class="text-muted-foreground mt-4 text-sm leading-relaxed max-w-[36ch]"
              >
                The <code class="font-mono text-xs">{">"} 18</code> mutant survived.
                Boundary value 18 is never tested — your suite can't tell <code
                  class="font-mono text-xs">{">="}</code
                > from <code class="font-mono text-xs">{">"}</code>.
              </p>
            </div>
            <div>
              <EyebrowLabel>
                <span class="text-destructive mr-1">✗</span>the tests
              </EyebrowLabel>
              <Card variant="destructive">
                <Code
                  lang="r"
                  code={`test_that("is_adult returns TRUE for adults", {
  expect_true(is_adult(25))  # passes even with age > 18
})

test_that("is_adult returns FALSE for minors", {
  expect_false(is_adult(10))  # passes even with age > 18
})`}
                />
              </Card>
            </div>
          </div>
        </Animate>

        <Animate>
          <div class="py-10 border-b border-foreground/10">
            <EyebrowLabel>run mutation testing</EyebrowLabel>
            <Card>
              <Code
                lang="r"
                code={`> muttest::muttest(plan)
#> ℹ Mutation Testing
#>   |   K |   S |   E |   T |   % | Mutator  | File
#> ✔ |   1 |   0 |   0 |   1 | 100 | >= → <=  | is_adult.R
#> x |   1 |   1 |   0 |   2 |  50 | >= → >   | is_adult.R
#>
#> ── Survived Mutants ─────────────────────────────────────────────────────────
#> is_adult.R  >= → >
#>   2-   age >= 18
#>   2+   age > 18
#>
#> ── Results ──────────────────────────────────────────────────────────────────
#> [ KILLED 1 | SURVIVED 1 | ERRORS 0 | TOTAL 2 | SCORE 50.0% ]`}
              />
            </Card>
          </div>
        </Animate>

        <Animate>
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 items-start pt-10 pb-0"
          >
            <div>
              <EyebrowLabel>after the fix</EyebrowLabel>
              <div
                class="text-[clamp(5rem,12vw,9rem)] font-bold leading-none tabular-nums text-ocean-green-400 js-count-up"
                data-target="100"
              >
                0%
              </div>
              <p
                class="text-muted-foreground mt-4 text-sm leading-relaxed max-w-[36ch]"
              >
                Every mutation triggers a failure. Adding the boundary test
                kills the survivor.
              </p>
            </div>
            <div>
              <EyebrowLabel>
                <span class="text-success mr-1">✓</span>the fix
              </EyebrowLabel>
              <Card variant="success">
                <Code
                  lang="r"
                  transformers={[transformerNotationDiff()]}
                  code={`test_that("is_adult returns TRUE for adults", {
  expect_true(is_adult(25))
})

test_that("is_adult returns FALSE for minors", {
  expect_false(is_adult(10))
})

test_that("is_adult is TRUE at the boundary", { # [!code ++]
  expect_true(is_adult(18))  # kills >= → > # [!code ++]
}) # [!code ++]`}
                />
              </Card>
            </div>
          </div>
        </Animate>
      </div>

      <div class="pt-12 pb-8">
        <a href="https://jakubsobolewski.com/muttest/" target="_blank">
          <Button size="xl" className="text-2xl" variant="pill" shape="pill">
            Patch the gaps in your tests
            <CircleArrowRight className="inline-block size-[1.5em] ml-2" />
          </Button>
        </a>
      </div>
    </div>
  </div>
</Section>

<script>
  function animateCount(el: HTMLElement, target: number, duration: number) {
    const start = performance.now();
    const update = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // ease-out-quart
      const eased = 1 - Math.pow(1 - progress, 4);
      el.textContent = Math.round(eased * target) + "%";
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target ?? "0", 10);
          animateCount(el, target, 1200);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 },
  );

  document.querySelectorAll<HTMLElement>(".js-count-up").forEach((el) => {
    observer.observe(el);
  });
</script>

<script>
  import "@/scripts/stepAnimation";
</script>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const container = entry.target as HTMLElement;
        const line = container.querySelector<HTMLElement>(".js-strike-line");
        const result =
          container.querySelector<HTMLElement>(".js-strike-result");
        if (!line || !result) return;

        line.style.transition = "width 0.5s cubic-bezier(0.4,0,0.2,1)";
        line.style.width = "100%";

        setTimeout(() => {
          result.style.transition = "opacity 0.5s ease, transform 0.5s ease";
          result.style.opacity = "1";
          result.style.transform = "translateY(0)";
        }, 550);

        observer.unobserve(container);
      });
    },
    { threshold: 0.5 },
  );

  document.querySelectorAll<HTMLElement>(".js-strike-reveal").forEach((el) => {
    observer.observe(el);
  });
</script>
