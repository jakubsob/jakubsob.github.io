---
import { Picture } from "astro:assets";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import authorImage from "/public/author.png";
---

<Section id="about" variant="secondary">
  <div
    class="w-full xl:max-w-screen-xl 2xl:max-w-[1400px] xl:mx-auto px-4 pt-16 pb-24 md:pt-20 md:pb-32"
  >
    <div
      class="grid grid-cols-1 lg:grid-cols-12 place-items-center lg:place-items-start"
    >
      <div class="lg:col-[2/6] lg:row-[1/2]">
        <Animate>
          <h2
            class="w-full text-[clamp(2.8rem,5.6vw,6rem)] font-bold uppercase leading-[0.86] tracking-[-0.04em]"
          >
            I'm Jakub Sobolewski
          </h2>
        </Animate>
      </div>
      <div class="lg:col-[2/6] lg:row-[2/3] max-w-[62ch]">
        <Animate>
          <div
            class="space-y-6 font-light font-serif text-base md:text-lg leading-relaxed"
          >
            <p>
              Software engineer specializing in R, with 5+ years writing and
              testing production code in the R and Shiny ecosystem.
            </p>
            <p>
              My conviction: automated testing is how teams build software they
              can trust. I started caring about this after working on a project
              where every code change required a live connection to production.
              Terrible experience, fixable problem.
            </p>
            <p>
              Tests should make development faster and more confident, not
              slower and more ceremonial. I write about finding strategies that
              actually fit the way real teams work.
            </p>
          </div>
        </Animate>
      </div>
      <div
        class="lg:col-[6/11] lg:row-[1/3] lg:w-full lg:place-self-end lg:flex lg:flex-row lg:justify-end"
      >
        <Animate>
          <div class="min-w-0 max-w-[380px]">
            <Picture
              src={authorImage}
              alt="Jakub Sobolewski"
              class="w-full h-auto object-cover aspect-[3/4]"
              widths={[220, 320, 480, 640]}
              sizes="(min-width: 1024px) 28vw, 70vw"
            />
          </div>
        </Animate>
      </div>
    </div>
  </div>
</Section>
