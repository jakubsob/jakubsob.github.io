---
import { Picture } from "astro:assets";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import authorImage from "/public/author.png";
import Grid from "../../pages/grid.png";
---

<Section id="about" variant="dark">
  <div class="pt-16 pb-24 md:pt-20 md:pb-32 relative">
    <div class="absolute z-0 bottom-0 left-0 size-full">
      <Picture
        src={Grid}
        class="size-full object-cover object-[center_top] invert opacity-10"
        alt="Hero background"
      />
    </div>
    <div class="container">
      <div
        class="grid grid-cols-1 lg:grid-cols-[2fr_7fr] gap-12 lg:gap-16 items-start"
      >
        <Animate>
          <div class="w-full max-w-[200px] lg:max-w-none">
            <Picture
              src={authorImage}
              alt="Jakub Sobolewski"
              class="w-full h-auto object-cover border bg-card aspect-[3/4]"
              widths={[200, 320, 480]}
              sizes="(min-width: 1024px) 18vw, 200px"
            />
          </div>
        </Animate>
        <Animate>
          <div class="space-y-0">
            <h2
              class="text-[clamp(2.5rem,5vw,5.5rem)] font-bold uppercase leading-[0.88] tracking-[-0.03em] mb-8 md:mb-10"
            >
              I'm Jakub<br />Sobolewski
            </h2>
            <div
              class="space-y-6 font-light font-serif text-base md:text-lg leading-relaxed"
            >
              <p>
                Software engineer specializing in R, with 5+ years writing and
                testing production code in the R and Shiny ecosystem.
              </p>
              <p>
                My conviction: automated testing is how teams build software
                they can trust. I started caring about this after working on a
                project where every code change required a live connection to
                production. Terrible experience, fixable problem.
              </p>
              <p>
                Tests should make development faster and more confident, not
                slower and more ceremonial. I write about finding strategies
                that actually fit the way real teams work.
              </p>
            </div>
          </div>
        </Animate>
      </div>
    </div>
  </div>
</Section>
