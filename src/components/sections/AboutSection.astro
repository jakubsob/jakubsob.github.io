---
import { Picture } from "astro:assets";
import { Section } from "@/components/ui/section";
import { Animate } from "@/components/ui/animate";
import authorImage from "/public/author.png";
import Grid2 from "../../pages/grid2.png";
---

<Section id="about" variant="light">
  <div class="pt-20 pb-40 relative">
    <div class="absolute z-0 bottom-0 left-0 size-full">
      <Picture
        src={Grid2}
        class="size-full object-cover object-[center_top] invert opacity-5 dark:opacity-40"
        alt="Hero background"
      />
    </div>
    <div class="px-6 md:px-12 lg:px-16">
      <Animate>
        <h2
          class="text-[clamp(3rem,9vw,8rem)] font-bold uppercase leading-[0.88] tracking-[-0.03em] mb-16"
        >
          I'm Jakub<br />Sobolewski
        </h2>
      </Animate>
      <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-12 lg:gap-24 items-start">
        <Animate>
          <div class="w-48 h-48 lg:w-64 lg:h-64 flex-shrink-0">
            <Picture
              src={authorImage}
              alt="Jakub Sobolewski"
              class="w-full h-full object-cover border bg-light"
              widths={[192, 256, 512]}
              sizes="(min-width: 1024px) 256px, 192px"
            />
          </div>
        </Animate>
        <Animate>
          <div
            class="max-w-[58ch] space-y-6 font-light font-serif text-base md:text-lg leading-relaxed"
          >
            <p>
              I'm a software engineer specializing in R with 5+ years of
              experience.
            </p>
            <p>
              I believe automated testing is the key to building quality software.
            </p>
            <p>
              My journey into R testing began with a project where, to write any
              code, you had to be connected to the production environment.
              Terrible developer experience.
            </p>
            <p>
              I'm particularly passionate about knowledge sharing, which is why I
              maintain an active blog and R Tests Gallery. When we share our
              testing experiences (both successes and failures) we all become
              better developers.
            </p>
            <p>
              I approach testing with a practical mindset: tests should make
              development faster and more confident, not slower and more
              burdensome. My goal is to help teams find testing strategies that
              actually enhance their workflow.
            </p>
          </div>
        </Animate>
      </div>
    </div>
  </div>
</Section>
