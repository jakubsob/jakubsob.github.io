---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  titleSEO?: string;
  description?: string;
  descriptionSEO?: string;
  image?: string;
  ogType?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  math?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title: titlePrimary,
  titleSEO,
  description: descriptionPrimary,
  descriptionSEO,
  image = "/ogimg-home.png",
  ogType = "website",
  pubDate,
  updatedDate,
  tags = [],
  author = "Jakub Sobolewski",
  math = false,
} = Astro.props;

const title = titleSEO || titlePrimary;
const description = descriptionSEO || descriptionPrimary;
const isArticle = ogType === "article";

const googleAnalyticsID = "G-735BLDHJRX";
const gtagUrl = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsID}`;
const shouldLoadAnalytics = import.meta.env.PROD;
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="author" content={author} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {
    isArticle && (
      <>
        {pubDate && (
          <meta
            property="article:published_time"
            content={pubDate.toISOString()}
          />
        )}
        {updatedDate && (
          <meta
            property="article:modified_time"
            content={updatedDate.toISOString()}
          />
        )}
        <meta property="article:author" content={author} />
        {tags.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )
  }

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />
  <slot />

  <link
    rel="alternate"
    type="application/rss+xml"
    title={title}
    href={new URL("rss-r.xml", Astro.site)}
  />

  <!-- Preconnect to deferred third-party origins -->
  <link rel="preconnect" href="https://assets.mailerlite.com" crossorigin />
  <link rel="dns-prefetch" href="https://assets.mailerlite.com" />
  <link rel="preconnect" href="https://assets.mlcdn.com" crossorigin />
  <link rel="dns-prefetch" href="https://assets.mlcdn.com" />
  <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />

  <!--
    Defer third-party scripts (GA + MailerLite) until the browser is idle or
    the user first interacts, keeping them off the critical path.
  -->
  <script is:inline define:vars={{ gtagUrl, googleAnalyticsID, shouldLoadAnalytics }}>
    (function () {
      let loaded = false;

      function inject(src) {
        const s = document.createElement("script");
        s.async = true;
        s.src = src;
        document.head.appendChild(s);
      }

      // MailerLite stub so calls queue before universal.js arrives.
      window.ml =
        window.ml ||
        function () {
          (window.ml.q = window.ml.q || []).push(arguments);
        };

      if (shouldLoadAnalytics) {
        // GA stub so events queue before gtag.js arrives.
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () {
          window.dataLayer.push(arguments);
        };
        window.gtag("js", new Date());
        window.gtag("config", googleAnalyticsID);
      }

      function loadThirdParty() {
        if (loaded) return;
        loaded = true;
        inject("https://assets.mailerlite.com/js/universal.js");
        window.ml("account", "1677606");
        if (shouldLoadAnalytics) {
          inject(gtagUrl);
        }
      }

      const events = ["scroll", "pointerdown", "keydown", "touchstart"];
      function onInteraction() {
        events.forEach((e) => window.removeEventListener(e, onInteraction));
        loadThirdParty();
      }
      events.forEach((e) =>
        window.addEventListener(e, onInteraction, { once: true, passive: true })
      );

      if ("requestIdleCallback" in window) {
        requestIdleCallback(loadThirdParty, { timeout: 5000 });
      } else {
        setTimeout(loadThirdParty, 4000);
      }
    })();
  </script>

  <!-- Developer Easter egg -->
  <script is:inline>
    (function () {
      var msg = [
        "%c# jakubsob.github.io",
        "%c",
        "%c# Hey, you opened the console — fellow developer!",
        "%c# This site is built with Astro, React, and Tailwind.",
        "%c# Source: github.com/jakubsob/jakubsob.github.io",
        "%c#",
        "%c# If R testing is your thing, you're in the right place.",
      ].join("\n");
      var style = "color: #7dd3fc; font-family: monospace; font-size: 13px;";
      var muted = "color: #6b7280; font-family: monospace; font-size: 13px;";
      console.log(
        msg,
        style, muted, muted, muted, muted, muted, muted
      );
    })();
  </script>

  <!-- Follow.it  -->
  <meta name="follow.it-verification-code" content="UzA851QwnL0Gqry6AJNE" />

  {shouldLoadAnalytics && (
    <link rel="preconnect" href="https://www.googletagmanager.com/" />
  )}
  {
    math && (
      <>
        <link rel="preconnect" href="https://cdn.jsdelivr.net" />
        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
        />
      </>
    )
  }
  <ClientRouter />
</head>
