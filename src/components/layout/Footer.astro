---
import { Section } from "@/components/ui/section";
import { EyebrowLabel } from "@/components/ui/eyebrow-label";
import { Animate } from "@/components/ui/animate";
import Subscribe from "@/components/features/Subscribe.astro";
import { getFooterRoutes, getSocialLinks } from "../../lib/routes";

const today = new Date();

const footerRoutes = getFooterRoutes();
const socialLinks = getSocialLinks();
---

<footer>
  <Section variant="darker">
    <div class="container mx-auto h-full flex flex-col justify-between">
      <div
        class="grid grid-cols-1 gap-12 lg:gap-20 lg:grid-cols-2 place-items-start
        h-full
        text-base lg:text-4xl
        py-16 lg:py-40"
      >
        <div class="lg:justify-self-center flex flex-col gap-8">
          <Animate client:visible>
            <p
              class="text-[clamp(2.5rem,5vw,5rem)] font-bold uppercase leading-[0.88] tracking-[-0.03em]"
            >
              Learn efficient R development
            </p>
            <div class="text-lg mt-8">
              <Subscribe variant="blog" />
            </div>
          </Animate>
        </div>
        <div class="lg:justify-self-center font-light">
          <Animate client:visible delay="200">
            <div class="flex flex-row gap-10">
              <div class="flex flex-col gap-4">
                <EyebrowLabel>Quick links</EyebrowLabel>
                <ul class="list-none text-muted-foreground space-y-4">
                  {
                    footerRoutes.map((route) => (
                      <li>
                        <a href={route.path} class="link-underline">
                          {route.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
              <div class="flex flex-col gap-4">
                <EyebrowLabel>Let's connect</EyebrowLabel>
                <ul class="list-none text-muted-foreground space-y-4">
                  {
                    socialLinks.map((link) => (
                      <li>
                        <a
                          href={link.path}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link-underline"
                        >
                          {link.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </Animate>
        </div>
      </div>
      <div
        class="flex items-center justify-between text-sm text-muted-foreground mt-auto pb-8 lg:pb-12"
      >
        <Animate client:visible delay="400">
          <span>&copy; {today.getFullYear()} Jakub Sobolewski</span>
        </Animate>
        <Animate client:visible delay="500" className="hidden sm:inline">
          <span>Made by me</span>
        </Animate>
      </div>
    </div>
  </Section>
</footer>
