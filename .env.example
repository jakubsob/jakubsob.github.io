# ─────────────────────────────────────────────────────────────────────────────
# SITE build env. Copy to `.env` (gitignored) for local dev. In production set
# the same vars in your Pages/Actions build environment.
#
# Only NON-secret, build-time values belong here. Anything PUBLIC_* is compiled
# into the browser bundle, so it must be safe to expose. The newsletter's real
# secrets live with the Worker / GitHub Actions, NOT in this file.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub API token for increased public-API rate limits (package stats, etc).
# Create at https://github.com/settings/tokens — no special permissions needed.
# Unrelated to the newsletter's data-repo token.
PRIVATE_GITHUB_TOKEN=your_github_token_here

# ── Newsletter ──────────────────────────────────────────────────────────────

# Public base URL of the newsletter Cloudflare Worker. The subscribe form POSTs
# here. Get it from `wrangler deploy` output (…workers.dev) or your custom domain.
PUBLIC_NEWSLETTER_API=

# Cloudflare Turnstile **Site Key** (the PUBLIC half of the key pair).
# Where: Cloudflare dashboard → Turnstile → your widget → "Site Key".
# This is embedded in the page; it is meant to be public.
# ⚠️  The matching "Secret Key" is NOT used here — it is a Worker secret
#     (TURNSTILE_SECRET in newsletter/worker/.dev.vars / `wrangler secret put`).
# Leave blank to disable the widget locally.
PUBLIC_TURNSTILE_SITEKEY=
